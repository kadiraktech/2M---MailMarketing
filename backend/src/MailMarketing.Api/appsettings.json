{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=mailmarketing;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "MailMarketingApi",
    "Audience": "MailMarketingFrontend",
    "SecretKey": "CHANGE_THIS_TO_A_LONG_SECRET_32CHARS_MINIMUM",
    "ExpireMinutes": 120
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "QueueWorker": {
    "PollIntervalSeconds": 3,
    "MaxConcurrentJobs": 5,
    "EmailTimeoutSeconds": 30,
    "MaxRetryCount": 3
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "User": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
