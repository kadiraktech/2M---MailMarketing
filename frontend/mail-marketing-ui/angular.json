{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "mail-marketing-ui": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/mail-marketing-ui",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/assets"],
            "styles": [
              "node_modules/@coreui/coreui/dist/css/coreui.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "node_modules/primeicons/primeicons.css",
              "node_modules/quill/dist/quill.snow.css",
              "src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "serviceWorker": "ngsw-config.json"
            },
            "development": { "optimization": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "mail-marketing-ui:build:production" },
            "development": { "buildTarget": "mail-marketing-ui:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": "1ddfbc61-a6d1-492c-a4eb-fdfbba72a231"
  }
}

